# Local development environment for opencode-router
# Copy to .env.local, then run: pnpm dev  (loaded automatically via tsx --env-file)
#
# Prerequisites:
#   1. Generate a temp kubeconfig: ./scripts/create-local-kubeconfig.sh
#   2. Start the SPA dev server: cd ../opencode-router-app && pnpm dev

# --- Auth bypass (dev only — never set in production) ---
DEV_EMAIL=dev@local.test

# --- Kubernetes ---
KUBECONFIG=/tmp/opencode-router-local.kubeconfig
OPENCODE_NAMESPACE=code
# Dev-only: the homelab k3s cluster uses a self-signed cert. Bun's TLS stack does not
# pick up the certificate-authority-data from the kubeconfig the way kubectl does.
# This disables TLS verification for the k8s API calls — safe for local dev only.
NODE_TLS_REJECT_UNAUTHORIZED=0

# --- Router config ---
PORT=3002
OPENCODE_IMAGE=ghcr.io/mrsimpson/opencode:latest
OPENCODE_PORT=4096
API_KEY_SECRET_NAME=opencode-api-keys
CONFIG_MAP_NAME=opencode-config-dir
IMAGE_PULL_SECRET_NAME=ghcr-pull-secret
STORAGE_CLASS=longhorn-uncritical
STORAGE_SIZE=2Gi

# The public domain — sessions are served at <proto>://<hash>.<ROUTER_DOMAIN>
# In local dev, use "localhost:3002" — browsers resolve *.localhost to 127.0.0.1
# natively (no /etc/hosts needed). Session URLs become http://<hash>.localhost:3002
# In production set this to the real domain: opencode-router.no-panic.org
ROUTER_DOMAIN=localhost:3002

# Optional: auto-clone a repo for new sessions
# DEFAULT_GIT_REPO=https://github.com/your-org/your-repo.git

# Optional: idle pod cleanup timeout (default 30 min)
# IDLE_TIMEOUT_MINUTES=30

# Dev-only: fixed proxy target for the opencode pod (pod IPs are unreachable outside the cluster).
# Port-forward the user pod first: kubectl port-forward <pod-name> 4096:4096 -n opencode-router
# Then set this so the router proxies through localhost instead of the unreachable pod IP.
DEV_POD_PROXY_TARGET=http://localhost:4096

# Dev-only: proxy the setup UI to Vite dev server instead of serving static files.
# This enables HMR and eliminates the redirect loop (router is the single entry point).
# Start Vite with: cd ../opencode-router-app && pnpm dev
# Then open http://localhost:3002 (not localhost:5173)
DEV_VITE_URL=http://localhost:5173
