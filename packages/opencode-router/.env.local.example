# Local development environment for opencode-router
# Copy to .env.local, then run: npm run dev
# (The dev script sources this file automatically)
#
# Prerequisites:
#   1. Generate a temp kubeconfig: ./scripts/create-local-kubeconfig.sh
#   2. Build the router: bun run build
#   3. Start the SPA dev server: cd ../opencode-router-app && bun run dev

# --- Auth bypass (dev only — never set in production) ---
export DEV_EMAIL=dev@local.test

# --- Kubernetes ---
export KUBECONFIG=/tmp/opencode-router-local.kubeconfig
export OPENCODE_NAMESPACE=opencode-router

# --- Router config ---
export PORT=3002
export OPENCODE_IMAGE=ghcr.io/mrsimpson/opencode:latest
export OPENCODE_PORT=4096
export API_KEY_SECRET_NAME=opencode-api-keys
export CONFIG_MAP_NAME=opencode-config-dir
export IMAGE_PULL_SECRET_NAME=ghcr-pull-secret
export STORAGE_CLASS=longhorn-uncritical
export STORAGE_SIZE=2Gi

# Optional: auto-clone a repo for new sessions
# export DEFAULT_GIT_REPO=https://github.com/your-org/your-repo.git

# Optional: idle pod cleanup timeout (default 30 min)
# export IDLE_TIMEOUT_MINUTES=30

# Dev-only: fixed proxy target for the opencode pod (pod IPs are unreachable outside the cluster).
# Port-forward the user pod first: kubectl port-forward <pod-name> 4096:4096 -n opencode-router
# Then set this so the router proxies through localhost instead of the unreachable pod IP.
export DEV_POD_PROXY_TARGET=http://localhost:4096

# Dev-only: proxy the setup UI to Vite dev server instead of serving static files.
# This enables HMR and eliminates the redirect loop (router is the single entry point).
# Start Vite with: cd ../opencode-router-app && bun run dev
# Then open http://localhost:3002 (not localhost:5173)
export DEV_VITE_URL=http://localhost:5173
