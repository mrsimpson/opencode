{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@ex-machina/opencode-anthropic-auth@1.5.1", "@codemcp/workflows-opencode@6.11.1"],
  "mcp": {
    "knowledge": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/knowledge-server"]
    },
    "agentskills": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/skills-server"]
    },
    "workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "skilled"
      }
    },
    "office_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "office"
      }
    }
  },
  "tools": {
    "workflows*": false,
    "office_workflows*": false
  },
  "provider": {
    "openrouter": {
      "models": {}
    },
    "openrouter-free": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["OPENROUTER_FREE_API_KEY"],
      "options": {
        "name": "openrouter-free",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {}
    }
  }
}
