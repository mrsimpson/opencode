{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@ex-machina/opencode-anthropic-auth@1.5.1", "@codemcp/workflows-opencode@6.11.1"],
  "mcp": {
    "knowledge": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/knowledge-server"]
    },
    "agentskills": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/skills-server"]
    },
    "workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "skilled"
      }
    },
    "office_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "office"
      }
    }
  },
  "permission": {
    "workflows_start_development": "deny",
    "workflows_proceed_to_phase": "deny",
    "workflows_whats_next": "deny",
    "workflows_conduct_review": "deny",
    "workflows_list_workflows": "deny",
    "office_workflows_start_development": "deny",
    "office_workflows_proceed_to_phase": "deny",
    "office_workflows_whats_next": "deny",
    "office_workflows_conduct_review": "deny",
    "office_workflows_list_workflows": "deny"
  },
  "provider": {
    "openrouter": {
      "models": {}
    },
    "openrouter-free": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["OPENROUTER_FREE_API_KEY"],
      "options": {
        "name": "openrouter-free",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {}
    }
  }
}
