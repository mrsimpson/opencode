{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@ex-machina/opencode-anthropic-auth@1.7.5", "@codemcp/workflows-opencode@6.14.3"],
  "model": "opencode/big-pickle",
  "default_agent": "workflow",
  "mcp": {
    "knowledge": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/knowledge-server"]
    },
    "agentskills": {
      "type": "local",
      "command": ["npx", "-y", "@codemcp/skills-server"]
    },
    "architecture_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "architecture"
      }
    },
    "office_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "office"
      }
    },
    "skilled_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "skilled"
      }
    },
    "vibe_workflows": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "@codemcp/workflows-server@latest"]
    }
  },
  "permission": {
    "architecture_workflows_*": "deny",
    "office_workflows_*": "deny",
    "skilled_workflows_*": "deny",
    "vibe_workflows_*": "deny",
    "start_development": "deny",
    "proceed_to_phase": "deny",
    "conduct_review": "deny",
    "reset_development": "deny",
    "setup_project_docs": "deny"
  },
  "provider": {
    "openrouter": {
      "models": {}
    },
    "openrouter-free": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["OPENROUTER_FREE_API_KEY"],
      "options": {
        "name": "openrouter-free",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {}
    }
  }
}
