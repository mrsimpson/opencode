{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "@codemcp/workflows-opencode@6.17.0",
    "/etc/opencode-plugin/index.ts"
  ],
  "model": "opencode/big-pickle",
  "default_agent": "workflow",
  "mcp": {
    "knowledge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@codemcp/knowledge-server"
      ]
    },
    "agentskills": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@codemcp/skills-server"
      ]
    },
    "architecture_workflows": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@codemcp/workflows-server@latest"
      ],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "architecture"
      }
    },
    "office_workflows": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@codemcp/workflows-server@latest"
      ],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "office"
      }
    },
    "skilled_workflows": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@codemcp/workflows-server@latest"
      ],
      "environment": {
        "VIBE_WORKFLOW_DOMAINS": "skilled"
      }
    },
    "vibe_workflows": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@codemcp/workflows-server@latest"
      ]
    }
  },
  "permission": {
    "architecture_workflows_*": "deny",
    "office_workflows_*": "deny",
    "skilled_workflows_*": "deny",
    "vibe_workflows_*": "deny",
    "start_development": "deny",
    "proceed_to_phase": "deny",
    "conduct_review": "deny",
    "reset_development": "deny",
    "setup_project_docs": "deny"
  },
  "provider": {
    "openrouter": {
      "models": {
        "anthropic/claude-sonnet-4.6": {},
        "anthropic/claude-sonnet-4.5": {},
        "anthropic/claude-3.7-sonnet": {},
        "anthropic/claude-haiku-4.5": {},
        "openai/gpt-4.1": {},
        "openai/o4-mini": {},
        "google/gemini-2.5-pro": {},
        "google/gemini-2.5-flash": {},
        "deepseek/deepseek-r1-0528": {},
        "deepseek/deepseek-v3.2": {},
        "qwen/qwen3-coder": {},
        "mistralai/devstral-medium": {},
        "moonshotai/kimi-k2": {}
      }
    },
    "openrouter-free": {
      "npm": "@ai-sdk/openai-compatible",
      "env": [
        "OPENROUTER_FREE_API_KEY"
      ],
      "options": {
        "name": "openrouter-free",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "qwen/qwen3-coder:free": {},
        "google/gemma-4-31b-it:free": {},
        "google/gemma-3-27b-it:free": {},
        "meta-llama/llama-3.3-70b-instruct:free": {},
        "openai/gpt-oss-120b:free": {},
        "minimax/minimax-m2.5:free": {},
        "nvidia/nemotron-3-super-120b-a12b:free": {}
      }
    }
  }
}