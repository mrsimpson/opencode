#!/bin/sh
set -e
# Check if bun version matches package.json
# keep in sync with packages/script/src/index.ts semver qualifier
bun -e '
import { semver } from "bun";
const pkg = await Bun.file("package.json").json();
const expectedBunVersion = pkg.packageManager?.split("@")[1];
if (!expectedBunVersion) {
  throw new Error("packageManager field not found in root package.json");
}
const expectedBunVersionRange = `^${expectedBunVersion}`;
if (!semver.satisfies(process.versions.bun, expectedBunVersionRange)) {
  throw new Error(`This script requires bun@${expectedBunVersionRange}, but you are using bun@${process.versions.bun}`);
}
if (process.versions.bun !== expectedBunVersion) {
  console.warn(`Warning: Bun version ${process.versions.bun} differs from expected ${expectedBunVersion}`);
}
'
# Typecheck fork packages only — upstream packages are gated by upstream CI.
echo "pre-push: typechecking opencode-router..."
(cd packages/opencode-router && pnpm typecheck)

echo "pre-push: typechecking opencode-router-app..."
(cd packages/opencode-router-app && bun run typecheck)

echo "pre-push: testing opencode-router..."
(cd packages/opencode-router && bun test src/config.test.ts src/api.test.ts && bun test src/pod-manager.test.ts)

echo "pre-push: testing opencode-router-app..."
(cd packages/opencode-router-app && bun test src/)

# --- compatibility guard ---
# Warn (non-blocking) if upstream-owned paths are touched in commits not yet on the remote.
UPSTREAM_PATHS="packages/opencode/ packages/app/ packages/ui/ packages/sdk/ packages/desktop/"
REMOTE=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
if [ -n "$REMOTE" ]; then
  CHANGED=$(git diff --name-only "$REMOTE"...HEAD 2>/dev/null || true)
  VIOLATIONS=""
  for p in $UPSTREAM_PATHS; do
    matches=$(echo "$CHANGED" | grep "^${p}" || true)
    if [ -n "$matches" ]; then
      VIOLATIONS="${VIOLATIONS}${matches}\n"
    fi
  done
  if [ -n "$VIOLATIONS" ]; then
    echo "pre-push WARNING: upstream-owned files modified:" >&2
    printf "%b" "$VIOLATIONS" >&2
    echo "These changes will fail the compatibility-guard CI job." >&2
  fi
fi
